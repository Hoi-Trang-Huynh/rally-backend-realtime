# Rally Realtime Server Configuration

# Server
PORT=8080

# Comma-separated list of allowed WebSocket origins (e.g. http://localhost:3000,https://app.rally.com)
# Leave empty to allow all origins (development only).
ALLOWED_ORIGINS=

# Redis
# Use localhost:6379 when running outside Docker.
# docker-compose overrides this to redis:6379 (the service name) automatically.
REDIS_ADDR=localhost:6379

# Firebase
# Path to service account credentials JSON. Leave empty on Cloud Run to use
# Application Default Credentials.
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# MongoDB (for chat persistence)
# MONGO_URI=mongodb://localhost:27017/rally
